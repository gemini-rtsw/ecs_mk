$(LINUX_ONLY)#!${INSTALL}/bin/${ARCH}/ecs-mk-IOC

cd ../..

epicsEnvSet("IOCSH_PS1","ecs-mk-IOC> ")
nfsMount("$(CFGSERVER)", "$(CFGREMOTE)", "$(CFGLOCAL)")

## Register all support components
dbLoadDatabase("dbd/ecs-mk-IOC.dbd")
ecs_mk_IOC_registerRecordDeviceDriver(pdbbase)

## Load records
dbLoadRecords("db/ecs.db", "top=ec:, prtop=pr:, port=/dev/ttyS1 41")
dbLoadRecords("db/ecsSad.db","sad=ec:sad:, ectop=ec:")
# dbLoadRecords("db/iocAdminRTEMS.db","IOC=ec:iocStats,TODFORMAT=%m/%d/%Y %H:%M:%S")

## Run this to trace the stages of iocInit
#traceIocInit

# Xycom 240 initialization
# COMMENTED OUT IN LAB SETUP
drvXy240Config(1, 32, 0xd000)

# The decimal file number, same as the 1785-KE node number
# 56: test PLC in the CPO instrument lab
# 11: production system and PLC in the SBF lab
#var drvAbDf1SrcStationNumber 56
var drvAbDf1SrcStationNumber 11

# Turn on A-B debug messages - WARNING! VERY VERBOSE!
#var drvAbDf1Debug 1

# Host and port for shutter Galil controller. Must be before iocInit

# hostAdd "ShutterGalil", "10.2.60.50"
#epicsEnvSet("ShutterGalil", "10.2.60.50")
epicsEnvSet("shutGalilTopHost", "10.2.60.50")
epicsEnvSet("shutGalilTopPort" , "4000")
epicsEnvSet("shutGalilBotHost", "10.2.60.50")
epicsEnvSet("shutGalilBotPort" , "4001")

# The following variables are used by the INIT command.
# They should be initialized before calling iocInit.
initSetParameters ("$(CFGFILE)/ecsInitMK.pv", "top=$(ECSTOP):")
# pvload, "$(CFGFILE)/ecsInitMK.pv", "top=$(ECSTOP):,version=."

iocInit

# Initialise the ECS database (no args, they were already set)
ecsPvload
